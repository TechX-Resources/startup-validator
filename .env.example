# Copy this file to .env and fill in values locally.
# Do NOT commit .env or real API keys.

# LLM provider (e.g. OpenAI, Claude) — use abstracted client in app/models/
OPENAI_API_KEY= your_key_here

# Web search tool (SerpAPI) — free tier: 100 queries/month at serpapi.com
SERPAPI_API_KEY=your_key_here

# App Configuration
DEBUG=true
LOG_LEVEL=INFO
APP_NAME=startup-idea-validator-agent
APP_VERSION=0.1.0

# Vector DB path for embeddings (e.g. Chroma) — placeholder until Week 4
VECTOR_DB_PATH=./data/embeddings
